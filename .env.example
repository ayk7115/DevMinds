# DevMind Environment Configuration

# Server Port
PORT=3000

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# GitHub Webhook Secret (Set this in GitHub Repo Settings)
GITHUB_WEBHOOK_SECRET=your_secret_here

# Telegram Integration
# 1. Message @BotFather on Telegram to create a bot and get a TOKEN.
# 2. Message @userinfobot to get your CHAT_ID.
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Groq Hybrid Cloud Chat
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Enterprise Integrations
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_BLOCKED_STATUS=Blocked
JIRA_READY_STATUS=Ready for Review
JIRA_IN_REVIEW_STATUS=In Review
DEVMIND_AUTO_JIRA=false

# Local Edge AI / Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_FAST_MODEL=llama3.1:8b-instruct-q4_K_M
OLLAMA_TINY_MODEL=phi3:mini-4k-instruct-q4_K_M
OLLAMA_EMBED_MODEL=nomic-embed-text
DEVMIND_LLM_CONCURRENCY=1
DEVMIND_CHUNK_CHARS=4600
DEVMIND_MAX_PROMPT_CHUNKS=8
DEVMIND_MAX_DIFF_CONTEXT=14000
DEVMIND_DIFF_FETCH_ATTEMPTS=3

# Optional debugging
SQLITE_VERBOSE=false
